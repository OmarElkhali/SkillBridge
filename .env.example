SPRING_PROFILES_ACTIVE=dev

# Supabase PostgreSQL connection for Spring Boot
# Provide either the exact JDBC URL from Supabase or build it with host/port/database.
DB_URL=jdbc:postgresql://db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD

# App security
JWT_SECRET=change-this-secret-key-change-this-secret-key
JWT_EXPIRATION_MS=86400000

# Frontend origin allowed to call the backend
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional seeded admin
ADMIN_EMAIL=admin@skillbridge.local
ADMIN_PASSWORD=Admin123!
ADMIN_FIRST_NAME=Platform
ADMIN_LAST_NAME=Admin
